         fhir:value [
           a fhir:String ;
           fhir:v "Normal"
         ]
       ] [
         fhir:value [
           a fhir:String ;
           fhir:v "Mildly unsteady"
         ]
       ] [
         fhir:value [
           a fhir:String ;
           fhir:v "Moderately unsteady"
         ]
       ] [
         fhir:value [
           a fhir:String ;
           fhir:v "Significantly impaired"
         ]
       ] )
     ] [
       fhir:linkId [ fhir:v "initial-assessment.muscle-soreness" ] ;
       fhir:text [ fhir:v "Muscle Soreness/Pain" ] ;
       fhir:type [ fhir:v "choice" ] ;
       fhir:answerOption ( [
         fhir:value [
           a fhir:String ;
           fhir:v "None"
         ]
       ] [
         fhir:value [
           a fhir:String ;
           fhir:v "Mild"
         ]
       ] [
         fhir:value [
           a fhir:String ;
           fhir:v "Moderate"
         ]
       ] [
         fhir:value [
           a fhir:String ;
           fhir:v "Severe"
         ]
       ] )
     ] [
       fhir:linkId [ fhir:v "initial-assessment.back-pain" ] ;
       fhir:text [ fhir:v "Back Pain Present" ] ;
       fhir:type [ fhir:v "boolean" ]
     ] [
       fhir:linkId [ fhir:v "initial-assessment.initial-plan" ] ;
       fhir:text [ fhir:v "Initial Reconditioning Plan" ] ;
       fhir:type [ fhir:v "text" ]
     ] )
  ] [
     fhir:linkId [ fhir:v "weekly-progress" ] ;
     fhir:text [ fhir:v "Weekly Progress Assessment" ] ;
     fhir:type [ fhir:v "group" ] ;
     fhir:item ( [
       fhir:linkId [ fhir:v "weekly-progress.week-number" ] ;
       fhir:text [ fhir:v "Week Number (R+)" ] ;
       fhir:type [ fhir:v "integer" ]
     ] [
       fhir:linkId [ fhir:v "weekly-progress.date" ] ;
       fhir:text [ fhir:v "Assessment Date" ] ;
       fhir:type [ fhir:v "date" ]
     ] [
       fhir:linkId [ fhir:v "weekly-progress.sessions-completed" ] ;
       fhir:text [ fhir:v "Reconditioning Sessions Completed" ] ;
       fhir:type [ fhir:v "integer" ]
     ] [
       fhir:linkId [ fhir:v "weekly-progress.aerobic-capacity" ] ;
       fhir:text [ fhir:v "Aerobic Capacity Recovery (%)" ] ;
       fhir:type [ fhir:v "decimal" ]
     ] [
       fhir:linkId [ fhir:v "weekly-progress.strength-recovery" ] ;
       fhir:text [ fhir:v "Strength Recovery (%)" ] ;
       fhir:type [ fhir:v "decimal" ]
     ] [
       fhir:linkId [ fhir:v "weekly-progress.balance-status" ] ;
       fhir:text [ fhir:v "Balance/Vestibular Status" ] ;
       fhir:type [ fhir:v "choice" ] ;
       fhir:answerOption ( [
         fhir:value [
           a fhir:String ;
           fhir:v "Returned to normal"
         ]
       ] [
         fhir:value [
           a fhir:String ;
           fhir:v "Improving"
         ]
       ] [
         fhir:value [
           a fhir:String ;
           fhir:v "Stable"
         ]
       ] [
         fhir:value [
           a fhir:String ;
           fhir:v "Requires intervention"
         ]
       ] )
     ] [
       fhir:linkId [ fhir:v "weekly-progress.concerns" ] ;
       fhir:text [ fhir:v "Concerns or Issues" ] ;
       fhir:type [ fhir:v "text" ]
     ] )
  ] [
     fhir:linkId [ fhir:v "final-assessment" ] ;
     fhir:text [ fhir:v "Final Reconditioning Assessment" ] ;
     fhir:type [ fhir:v "group" ] ;
     fhir:item ( [
       fhir:linkId [ fhir:v "final-assessment.date" ] ;
       fhir:text [ fhir:v "Final Assessment Date" ] ;
       fhir:type [ fhir:v "date" ]
     ] [
       fhir:linkId [ fhir:v "final-assessment.total-duration" ] ;
       fhir:text [ fhir:v "Total Reconditioning Duration (days)" ] ;
       fhir:type [ fhir:v "integer" ]
     ] [
       fhir:linkId [ fhir:v "final-assessment.aerobic-baseline" ] ;
       fhir:text [ fhir:v "Return to Aerobic Baseline" ] ;
       fhir:type [ fhir:v "boolean" ]
     ] [
       fhir:linkId [ fhir:v "final-assessment.strength-baseline" ] ;
       fhir:text [ fhir:v "Return to Strength Baseline" ] ;
       fhir:type [ fhir:v "boolean" ]
     ] [
       fhir:linkId [ fhir:v "final-assessment.full-duty-cleared" ] ;
       fhir:text [ fhir:v "Cleared for Full Duty" ] ;
       fhir:type [ fhir:v "boolean" ]
     ] [
       fhir:linkId [ fhir:v "final-assessment.clearance-date" ] ;
       fhir:text [ fhir:v "Clearance Date" ] ;
       fhir:type [ fhir:v "date" ]
     ] [
       fhir:linkId [ fhir:v "final-assessment.ongoing-issues" ] ;
       fhir:text [ fhir:v "Any Ongoing Issues" ] ;
       fhir:type [ fhir:v "text" ]
     ] )
  ] [
     fhir:linkId [ fhir:v "data-delivery" ] ;
     fhir:text [ fhir:v "Data Delivery" ] ;
     fhir:type [ fhir:v "group" ] ;
     fhir:item ( [
       fhir:linkId [ fhir:v "data-delivery.archive" ] ;
       fhir:text [ fhir:v "Data Archive System" ] ;
       fhir:type [ fhir:v "choice" ] ;
       fhir:answerOption ( [
         fhir:value [
           a fhir:Coding ;
           fhir:system [
             fhir:v "https://mitre.org/fhir/space-health/CodeSystem/nasa-data-archive-cs"^^xsd:anyURI ;
             fhir:l <https://mitre.org/fhir/space-health/CodeSystem/nasa-data-archive-cs>
           ] ;
           fhir:code [ fhir:v "mmis" ] ;
           fhir:display [ fhir:v "Medical Mission Information System" ]
         ]
       ] ) ;
       fhir:initial ( [
         fhir:value [
           a fhir:Coding ;
           fhir:system [
             fhir:v "https://mitre.org/fhir/space-health/CodeSystem/nasa-data-archive-cs"^^xsd:anyURI ;
             fhir:l <https://mitre.org/fhir/space-health/CodeSystem/nasa-data-archive-cs>
           ] ;
           fhir:code [ fhir:v "mmis" ] ;
           fhir:display [ fhir:v "Medical Mission Information System" ]
         ]
       ] )
     ] )
  ] ) . # 

