     ] )
  ] ) ; # 
  fhir:description [ fhir:v "NASA Medical Requirements Integration Document for EVA prebreathe protocol. Tracks oxygen prebreathe procedures to prevent decompression sickness."] ; # 
  fhir:purpose [ fhir:v "To document execution of EVA prebreathe protocol for decompression sickness prevention."] ; # 
  fhir:copyright [ fhir:v "NASA Johnson Space Center - Medical Requirements Integration Documents (MRIDs) JSC28913"] ; # 
  fhir:item ( [
     fhir:linkId [ fhir:v "overview" ] ;
     fhir:text [ fhir:v "Medical Requirements Overview" ] ;
     fhir:type [ fhir:v "group" ] ;
     fhir:item ( [
       fhir:linkId [ fhir:v "overview.mrid-number" ] ;
       fhir:text [ fhir:v "MRID Number and Title" ] ;
       fhir:type [ fhir:v "display" ] ;
       fhir:initial ( [
         fhir:value [
           a fhir:String ;
           fhir:v "MR087S EVA Prebreathe Protocol"
         ]
       ] )
     ] [
       fhir:linkId [ fhir:v "overview.purpose" ] ;
       fhir:text [ fhir:v "Purpose/Objectives" ] ;
       fhir:type [ fhir:v "text" ] ;
       fhir:initial ( [
         fhir:value [
           a fhir:String ;
           fhir:v "To denitrogenate crewmembers prior to EVA to reduce risk of decompression sickness (DCS) when transitioning from cabin pressure to suit pressure."
         ]
       ] )
     ] )
  ] [
