cr<a name=\"nasa-mrid-sponsor-cs-ascr\"> </a></td><td>Astronaut Strength Conditioning and Rehabilitation</td><td>NASA ASCR team responsible for fitness assessment and rehabilitation.</td></tr></table></div>"^^rdf:XMLLiteral ]
