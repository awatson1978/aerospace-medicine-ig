           ]
         ] [
           fhir:value [
             a fhir:String ;
             fhir:v "Grade 3 - Severe"
           ]
         ] )
       ] )
     ] [
       fhir:linkId [ fhir:v "postflight-ophth-results.comparison" ] ;
       fhir:text [ fhir:v "Comparison to Preflight" ] ;
       fhir:type [ fhir:v "choice" ] ;
       fhir:answerOption ( [
         fhir:value [
           a fhir:String ;
           fhir:v "No significant change"
         ]
       ] [
         fhir:value [
           a fhir:String ;
           fhir:v "SANS findings present"
         ]
       ] [
         fhir:value [
           a fhir:String ;
           fhir:v "Other changes"
         ]
       ] )
     ] [
       fhir:linkId [ fhir:v "postflight-ophth-results.notes" ] ;
       fhir:text [ fhir:v "Examination Notes" ] ;
       fhir:type [ fhir:v "text" ]
     ] )
  ] [
     fhir:linkId [ fhir:v "data-delivery" ] ;
     fhir:text [ fhir:v "Data Delivery" ] ;
     fhir:type [ fhir:v "group" ] ;
     fhir:item ( [
       fhir:linkId [ fhir:v "data-delivery.archive" ] ;
       fhir:text [ fhir:v "Data Archive Systems" ] ;
       fhir:type [ fhir:v "choice" ] ;
       fhir:repeats [ fhir:v true ] ;
       fhir:answerOption ( [
         fhir:value [
           a fhir:Coding ;
           fhir:system [
             fhir:v "https://mitre.org/fhir/space-health/CodeSystem/nasa-data-archive-cs"^^xsd:anyURI ;
             fhir:l <https://mitre.org/fhir/space-health/CodeSystem/nasa-data-archive-cs>
           ] ;
           fhir:code [ fhir:v "pacs" ] ;
           fhir:display [ fhir:v "Picture Archiving and Communication System" ]
         ]
       ] [
         fhir:value [
           a fhir:Coding ;
           fhir:system [
             fhir:v "https://mitre.org/fhir/space-health/CodeSystem/nasa-data-archive-cs"^^xsd:anyURI ;
             fhir:l <https://mitre.org/fhir/space-health/CodeSystem/nasa-data-archive-cs>
           ] ;
           fhir:code [ fhir:v "mmis" ] ;
           fhir:display [ fhir:v "Medical Mission Information System" ]
         ]
       ] )
     ] )
  ] [
     fhir:linkId [ fhir:v "postflight-debrief" ] ;
     fhir:text [ fhir:v "Postflight Debrief" ] ;
     fhir:type [ fhir:v "group" ] ;
     fhir:item ( [
