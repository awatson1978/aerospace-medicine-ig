           fhir:l <http://loinc.org>
         ] ;
         fhir:code [ fhir:v "73536-5" ] ;
         fhir:display [ fhir:v "Radiation dose" ]
       ] ) ;
       fhir:text [ fhir:v "Peak Dose Rate During Event (mSv/hr)" ] ;
       fhir:type [ fhir:v "decimal" ]
     ] [
       fhir:linkId [ fhir:v "exposure-tracking.total-event-dose" ] ;
       fhir:text [ fhir:v "Total Event Dose (mSv)" ] ;
       fhir:type [ fhir:v "decimal" ]
     ] [
       fhir:linkId [ fhir:v "exposure-tracking.dose-within-limits" ] ;
       fhir:text [ fhir:v "Dose Within Permissible Limits" ] ;
       fhir:type [ fhir:v "boolean" ] ;
       fhir:required [ fhir:v true ]
     ] )
  ] [
     fhir:linkId [ fhir:v "event-conclusion" ] ;
     fhir:text [ fhir:v "Event Conclusion" ] ;
     fhir:type [ fhir:v "group" ] ;
     fhir:item ( [
       fhir:linkId [ fhir:v "event-conclusion.all-clear-time" ] ;
       fhir:text [ fhir:v "All Clear Time (UTC)" ] ;
       fhir:type [ fhir:v "dateTime" ]
     ] [
       fhir:linkId [ fhir:v "event-conclusion.shelter-exit-time" ] ;
       fhir:text [ fhir:v "Shelter Exit Time (UTC)" ] ;
       fhir:type [ fhir:v "dateTime" ]
     ] [
       fhir:linkId [ fhir:v "event-conclusion.total-shelter-duration" ] ;
       fhir:text [ fhir:v "Total Time in Shelter (hours)" ] ;
       fhir:type [ fhir:v "decimal" ]
     ] [
       fhir:linkId [ fhir:v "event-conclusion.crew-health-status" ] ;
       fhir:text [ fhir:v "Crew Health Status Post-Event" ] ;
       fhir:type [ fhir:v "choice" ] ;
       fhir:answerOption ( [
         fhir:value [
           a fhir:String ;
           fhir:v "No symptoms reported"
         ]
       ] [
         fhir:value [
           a fhir:String ;
           fhir:v "Minor symptoms - monitoring"
         ]
       ] [
         fhir:value [
           a fhir:String ;
           fhir:v "Medical evaluation required"
         ]
       ] )
     ] [
       fhir:linkId [ fhir:v "event-conclusion.notes" ] ;
       fhir:text [ fhir:v "Event Notes" ] ;
       fhir:type [ fhir:v "text" ]
     ] )
  ] [
     fhir:linkId [ fhir:v "data-delivery" ] ;
     fhir:text [ fhir:v "Data Delivery" ] ;
     fhir:type [ fhir:v "group" ] ;
     fhir:item ( [
       fhir:linkId [ fhir:v "data-delivery.archive" ] ;
       fhir:text [ fhir:v "Data Archive System" ] ;
       fhir:type [ fhir:v "choice" ] ;
       fhir:answerOption ( [
         fhir:value [
           a fhir:Coding ;
           fhir:system [
             fhir:v "https://mitre.org/fhir/space-health/CodeSystem/nasa-data-archive-cs"^^xsd:anyURI ;
             fhir:l <https://mitre.org/fhir/space-health/CodeSystem/nasa-data-archive-cs>
           ] ;
           fhir:code [ fhir:v "areas" ] ;
           fhir:display [ fhir:v "Astronaut Radiation Exposure Assessment System" ]
         ]
       ] ) ;
       fhir:initial ( [
         fhir:value [
           a fhir:Coding ;
           fhir:system [
             fhir:v "https://mitre.org/fhir/space-health/CodeSystem/nasa-data-archive-cs"^^xsd:anyURI ;
             fhir:l <https://mitre.org/fhir/space-health/CodeSystem/nasa-data-archive-cs>
           ] ;
           fhir:code [ fhir:v "areas" ] ;
           fhir:display [ fhir:v "Astronaut Radiation Exposure Assessment System" ]
         ]
       ] )
     ] )
  ] ) . # 

